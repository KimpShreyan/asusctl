// ROG Control Center — Sidebar Navigation
// Armoury Crate style: grouped sections, red active indicator

import { ROGTheme } from "../theme.slint";
import { SideBarEntry } from "../types/monitor_types.slint";
export { SideBarEntry }

component SideBarSectionHeader inherits Rectangle {
    in property <string> text;
    height: 28px;
    background: transparent;

    HorizontalLayout {
        padding-left: ROGTheme.spacing-lg;
        padding-top: ROGTheme.spacing-sm;

        Text {
            color: ROGTheme.sidebar-section-text;
            font-size: ROGTheme.sidebar-section-font;
            font-weight: ROGTheme.weight-medium;
            text: root.text;
            vertical-alignment: center;
            letter-spacing: 0.5px;
        }
    }
}

component SideBarItem inherits Rectangle {
    in property <bool> selected;
    in property <bool> has-focus;
    in-out property <string> text <=> label.text;
    callback clicked <=> touch.clicked;

    min-height: self.visible ? 36px : 0px;
    background: transparent;

    // Active left indicator (3px red bar)
    Rectangle {
        x: 0px;
        y: (parent.height - 20px) / 2;
        width: 3px;
        height: 20px;
        border-radius: 1px;
        background: ROGTheme.accent;
        opacity: root.selected ? 1.0 : 0.0;
        animate opacity { duration: ROGTheme.anim-normal; }
    }

    // Hover background
    state := Rectangle {
        x: 3px;
        width: parent.width - 3px;
        height: parent.height;
        background: ROGTheme.bg-hover;
        border-radius: ROGTheme.radius-sm;
        opacity: 0;
        animate opacity { duration: ROGTheme.anim-fast; }
    }

    HorizontalLayout {
        padding-left: ROGTheme.spacing-lg;
        padding-right: ROGTheme.spacing-sm;

        label := Text {
            color: root.selected ? ROGTheme.accent : ROGTheme.text-secondary;
            vertical-alignment: center;
            font-size: ROGTheme.font-body;
            font-weight: root.selected ? ROGTheme.weight-medium : ROGTheme.weight-regular;
            animate color { duration: ROGTheme.anim-normal; }
        }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
    }

    states [
        pressed when touch.pressed: {
            state.opacity: 0.8;
        }
        hover when touch.has-hover: {
            state.opacity: 0.6;
            label.color: ROGTheme.text-primary;
        }
        selected when root.selected: {
            state.opacity: 0.0;
        }
        focused when root.has-focus: {
            state.opacity: 0.6;
        }
    ]
}

export component SideBar inherits Rectangle {
    in property <[SideBarEntry]> entries: [];
    in property <string> title <=> title-text.text;
    out property <int> current-item: 0;
    out property <int> current-focused: fs.has-focus ? fs.focused-tab : -1;

    width: ROGTheme.sidebar-width;
    forward-focus: fs;
    accessible-role: tab;
    accessible-delegate-focus: root.current-focused >= 0 ? root.current-focused : root.current-item;

    // Sidebar background
    Rectangle {
        background: ROGTheme.bg-secondary;
        // Right edge border
        Rectangle {
            x: parent.width - 1px;
            width: 1px;
            height: parent.height;
            background: ROGTheme.border-default;
        }

        fs := FocusScope {
            key-pressed(event) => {
                if (event.text == "\n") {
                    root.current-item = root.current-focused;
                    return accept;
                }
                if (event.text == Key.UpArrow) {
                    self.focused-tab = Math.max(self.focused-tab - 1, 0);
                    return accept;
                }
                if (event.text == Key.DownArrow) {
                    self.focused-tab = Math.min(self.focused-tab + 1, root.entries.length - 1);
                    return accept;
                }
                return reject;
            }
            key-released(event) => {
                if (event.text == " ") {
                    root.current-item = root.current-focused;
                    return accept;
                }
                return reject;
            }
            property <int> focused-tab: 0;
            x: 0;
            width: 0;
        }
    }

    VerticalLayout {
        alignment: start;
        spacing: 0px;

        // Title area
        Rectangle {
            height: 48px;
            HorizontalLayout {
                padding-left: ROGTheme.spacing-lg;
                alignment: start;

                title-text := Text {
                    font-size: ROGTheme.font-heading;
                    font-weight: ROGTheme.weight-bold;
                    color: ROGTheme.text-primary;
                    vertical-alignment: center;
                }
            }

            // Bottom glow line
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: ROGTheme.border-default;
            }
        }

        // Spacer
        Rectangle { height: ROGTheme.spacing-sm; }

        // Navigation items with section headers
        VerticalLayout {
            spacing: 2px;
            alignment: start;
            vertical-stretch: 0;

            for entry[index] in root.entries: VerticalLayout {
                spacing: 0px;
                visible: entry.available;

                // Section header (shown when entry has a non-empty section)
                if entry.section != "": SideBarSectionHeader {
                    text: entry.section;
                }

                SideBarItem {
                    clicked => {
                        root.current-item = index;
                    }
                    has-focus: index == root.current-focused;
                    text: entry.label;
                    selected: index == root.current-item;
                }
            }
        }

        // Push remaining content to bottom
        Rectangle { vertical-stretch: 1; }

        // Bottom slot for Quit button etc.
        VerticalLayout {
            @children
        }
    }
}
