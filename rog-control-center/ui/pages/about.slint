import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
import { ROGTheme } from "../theme.slint";

export component PageAbout inherits Rectangle {
    background: transparent;

    ScrollView {
        VerticalLayout {
            padding: ROGTheme.spacing-xl;
            spacing: ROGTheme.spacing-lg;
            alignment: start;

            Text {
                text: @tr("ROG Control Center");
                color: ROGTheme.text-primary;
                font-size: ROGTheme.font-title;
                font-weight: ROGTheme.weight-bold;
                horizontal-alignment: center;
            }

            // About card
            Rectangle {
                background: ROGTheme.bg-surface;
                border-radius: ROGTheme.radius-lg;
                border-width: 1px;
                border-color: ROGTheme.border-default;

                VerticalLayout {
                    padding: ROGTheme.spacing-lg;
                    spacing: ROGTheme.spacing-sm;

                    Text {
                        text: @tr("About");
                        color: ROGTheme.text-primary;
                        font-size: ROGTheme.font-heading;
                        font-weight: ROGTheme.weight-bold;
                    }

                    Text {
                        text: @tr("A control center for ASUS ROG laptops on Linux. Provides system tuning, fan curve editing, RGB keyboard control, and AniMe Matrix management.");
                        color: ROGTheme.text-secondary;
                        font-size: ROGTheme.font-body;
                        wrap: word-wrap;
                    }
                }
            }

            // Resources card
            Rectangle {
                background: ROGTheme.bg-surface;
                border-radius: ROGTheme.radius-lg;
                border-width: 1px;
                border-color: ROGTheme.border-default;

                VerticalLayout {
                    padding: ROGTheme.spacing-lg;
                    spacing: ROGTheme.spacing-sm;

                    Text {
                        text: @tr("Resources");
                        color: ROGTheme.text-primary;
                        font-size: ROGTheme.font-heading;
                        font-weight: ROGTheme.weight-bold;
                    }

                    Text {
                        text: "GitLab: gitlab.com/asus-linux/asusctl";
                        color: ROGTheme.text-secondary;
                        font-size: ROGTheme.font-body;
                    }

                    Text {
                        text: "GitHub: github.com/flukejones/asusctl";
                        color: ROGTheme.text-secondary;
                        font-size: ROGTheme.font-body;
                    }
                }
            }

            // Note
            Rectangle {
                background: ROGTheme.bg-surface;
                border-radius: ROGTheme.radius-lg;
                border-width: 1px;
                border-color: ROGTheme.border-default;

                VerticalLayout {
                    padding: ROGTheme.spacing-lg;
                    spacing: ROGTheme.spacing-sm;

                    Text {
                        text: @tr("Note");
                        color: ROGTheme.text-primary;
                        font-size: ROGTheme.font-heading;
                        font-weight: ROGTheme.weight-bold;
                    }

                    Text {
                        text: @tr("For advanced tuning features, a kernel with the asus-armoury driver is required.");
                        color: ROGTheme.text-secondary;
                        font-size: ROGTheme.font-body;
                        wrap: word-wrap;
                    }
                }
            }

            Text {
                text: @tr("Built with Slint UI");
                color: ROGTheme.text-disabled;
                font-size: ROGTheme.font-label;
                horizontal-alignment: center;
            }
        }
    }
}
