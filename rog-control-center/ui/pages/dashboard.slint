// ROG Control Center — Dashboard Page
// Matches ASUS Armoury Crate dashboard layout

import { ScrollView } from "std-widgets.slint";
import { ROGTheme } from "../theme.slint";
import { MonitorEntry, ProductInfo, FanModeEntry } from "../types/monitor_types.slint";

// ── Data global (set from Rust) ──

export global DashboardPageData {
    in-out property <ProductInfo> product: {
        product-name: "ASUS ROG Laptop",
        cpu-name: "",
        gpu-name: "",
        ram-info: "",
        bios-version: "",
    };

    in-out property <[MonitorEntry]> frequency-entries: [];
    in-out property <[MonitorEntry]> temperature-entries: [];
    in-out property <[MonitorEntry]> usage-entries: [];
    in-out property <[MonitorEntry]> fan-entries: [];
    in-out property <[MonitorEntry]> voltage-entries: [];

    in-out property <int> active-fan-mode: 1;
    in-out property <[FanModeEntry]> fan-modes: [
        { label: "Silent", active: false },
        { label: "Standard", active: true },
        { label: "Turbo", active: false },
        { label: "Full Speed", active: false },
    ];

    callback cb-set-fan-mode(int);
}

// ── Section header with ROG accent marker ──

component SectionHeader inherits Rectangle {
    in property <string> text;
    height: 32px;

    HorizontalLayout {
        spacing: ROGTheme.spacing-sm;
        alignment: start;

        // Red accent marker
        Rectangle {
            width: 4px;
            height: 16px;
            y: (parent.height - self.height) / 2;
            background: ROGTheme.accent;
            border-radius: 2px;
        }

        Text {
            text: root.text;
            color: ROGTheme.text-primary;
            font-size: ROGTheme.font-heading;
            font-weight: ROGTheme.weight-bold;
            vertical-alignment: center;
        }
    }
}

// ── Monitor data row ──

component MonitorRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <float> bar-percent: 0.0;
    in property <bool> show-bar: false;
    in property <color> bar-color: ROGTheme.monitor-freq;

    height: show-bar ? 28px : 24px;
    background: transparent;

    VerticalLayout {
        spacing: 0px;

        HorizontalLayout {
            padding-left: 0px;
            padding-right: 0px;
            height: 22px;

            Text {
                text: root.label;
                color: ROGTheme.text-secondary;
                font-size: ROGTheme.font-label;
                vertical-alignment: center;
                horizontal-alignment: left;
            }

            Text {
                text: root.value;
                color: ROGTheme.text-primary;
                font-size: ROGTheme.font-label;
                vertical-alignment: center;
                horizontal-alignment: right;
            }
        }

        // Colored progress bar
        if root.show-bar: Rectangle {
            height: 3px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 1px;

            Rectangle {
                x: 0px;
                y: 0px;
                height: parent.height;
                width: parent.width * Math.max(0.0, Math.min(1.0, root.bar-percent));
                background: root.bar-color;
                border-radius: 1px;
            }
        }
    }
}

// ── Monitor table (Frequency, Temperature, etc.) ──

component MonitorTable inherits Rectangle {
    in property <string> title;
    in property <color> bar-color: ROGTheme.monitor-freq;
    in property <[MonitorEntry]> entries;

    background: transparent;

    VerticalLayout {
        spacing: ROGTheme.spacing-xs;

        // Table header
        Text {
            text: root.title;
            color: ROGTheme.text-primary;
            font-size: 16px;
            font-weight: ROGTheme.weight-bold;
        }

        // Data rows
        for entry[idx] in root.entries: MonitorRow {
            label: entry.label;
            value: entry.value;
            bar-percent: entry.bar-percent;
            show-bar: entry.show-bar;
            bar-color: root.bar-color;
        }
    }
}

// ── Product info card ──

component ProductInfoCard inherits Rectangle {
    in property <ProductInfo> info;

    background: ROGTheme.bg-surface;
    border-radius: ROGTheme.radius-lg;
    border-width: 1px;
    border-color: ROGTheme.border-default;

    VerticalLayout {
        padding: ROGTheme.spacing-xl;
        spacing: ROGTheme.spacing-sm;
        alignment: center;

        // Product name
        Text {
            text: info.product-name;
            color: ROGTheme.text-primary;
            font-size: 20px;
            font-weight: ROGTheme.weight-bold;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // CPU
        if info.cpu-name != "": Text {
            text: info.cpu-name;
            color: ROGTheme.text-secondary;
            font-size: ROGTheme.font-body;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // GPU
        if info.gpu-name != "": Text {
            text: info.gpu-name;
            color: ROGTheme.text-secondary;
            font-size: ROGTheme.font-body;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // RAM + BIOS line
        if info.ram-info != "": Text {
            text: info.bios-version != ""
                ? info.ram-info + " | " + info.bios-version
                : info.ram-info;
            color: ROGTheme.text-disabled;
            font-size: ROGTheme.font-label;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

// ── System monitor panel (right side) ──

component SystemMonitorPanel inherits Rectangle {
    in property <[MonitorEntry]> frequency-entries;
    in property <[MonitorEntry]> temperature-entries;
    in property <[MonitorEntry]> usage-entries;
    in property <[MonitorEntry]> fan-entries;
    in property <[MonitorEntry]> voltage-entries;

    background: transparent;

    VerticalLayout {
        spacing: ROGTheme.spacing-lg;

        // "System Monitor" header
        SectionHeader { text: "System Monitor"; }

        // Top row: Frequency + Temperature
        HorizontalLayout {
            spacing: ROGTheme.spacing-xl;

            MonitorTable {
                title: "Frequency";
                bar-color: ROGTheme.monitor-freq;
                entries: root.frequency-entries;
            }

            MonitorTable {
                title: "Temperature";
                bar-color: ROGTheme.monitor-temp;
                entries: root.temperature-entries;
            }
        }

        // Middle row: Usage + Fan + Voltage
        HorizontalLayout {
            spacing: ROGTheme.spacing-xl;

            MonitorTable {
                title: "Usage";
                bar-color: ROGTheme.monitor-usage;
                entries: root.usage-entries;
            }

            MonitorTable {
                title: "Fan";
                bar-color: ROGTheme.monitor-fan;
                entries: root.fan-entries;
            }

            MonitorTable {
                title: "Voltage";
                bar-color: ROGTheme.monitor-voltage;
                entries: root.voltage-entries;
            }
        }
    }
}

// ── Fan mode button ──

component FanModeButton inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;

    width: 120px;
    height: 64px;
    background: transparent;
    border-radius: ROGTheme.radius-md;

    VerticalLayout {
        alignment: center;
        spacing: ROGTheme.spacing-xs;

        Text {
            text: root.label;
            color: root.active ? ROGTheme.accent : ROGTheme.text-secondary;
            font-size: ROGTheme.font-body;
            font-weight: root.active ? ROGTheme.weight-medium : ROGTheme.weight-regular;
            horizontal-alignment: center;
            animate color { duration: ROGTheme.anim-normal; }
        }

        // Active indicator line
        Rectangle {
            height: 2px;
            width: parent.width * 0.6;
            x: (parent.width - self.width) / 2;
            background: ROGTheme.accent;
            opacity: root.active ? 1.0 : 0.0;
            border-radius: 1px;
            animate opacity { duration: ROGTheme.anim-normal; }
        }
    }

    // Hover effect
    Rectangle {
        width: 100%;
        height: 100%;
        background: ROGTheme.bg-hover;
        border-radius: ROGTheme.radius-md;
        opacity: touch.has-hover ? 0.6 : 0.0;
        animate opacity { duration: ROGTheme.anim-fast; }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }
}

// ── Fan mode selector ──

component FanModeSelector inherits Rectangle {
    in property <[FanModeEntry]> modes;
    in-out property <int> active-mode;
    callback mode-selected(int);

    background: ROGTheme.bg-surface;
    border-radius: ROGTheme.radius-lg;
    border-width: 1px;
    border-color: ROGTheme.border-default;

    VerticalLayout {
        padding: ROGTheme.spacing-lg;
        spacing: ROGTheme.spacing-md;

        SectionHeader { text: "Fan Mode"; }

        HorizontalLayout {
            spacing: ROGTheme.spacing-sm;
            alignment: center;

            for entry[idx] in root.modes: FanModeButton {
                label: entry.label;
                active: idx == root.active-mode;
                clicked => {
                    root.active-mode = idx;
                    root.mode-selected(idx);
                }
            }
        }
    }
}

// ── Main dashboard page ──

export component PageDashboard inherits Rectangle {
    background: transparent;
    clip: true;

    ScrollView {
        VerticalLayout {
            padding: ROGTheme.spacing-xl;
            spacing: ROGTheme.spacing-xl;

            // Page title
            Text {
                text: @tr("Dashboard");
                color: ROGTheme.text-primary;
                font-size: ROGTheme.font-title;
                font-weight: ROGTheme.weight-bold;
            }

            // Main content: product info (left) + system monitor (right)
            HorizontalLayout {
                spacing: ROGTheme.spacing-xl;

                ProductInfoCard {
                    min-width: 280px;
                    max-width: 360px;
                    info: DashboardPageData.product;
                }

                SystemMonitorPanel {
                    frequency-entries: DashboardPageData.frequency-entries;
                    temperature-entries: DashboardPageData.temperature-entries;
                    usage-entries: DashboardPageData.usage-entries;
                    fan-entries: DashboardPageData.fan-entries;
                    voltage-entries: DashboardPageData.voltage-entries;
                }
            }

            // Fan mode quick selector
            FanModeSelector {
                modes: DashboardPageData.fan-modes;
                active-mode <=> DashboardPageData.active-fan-mode;
                mode-selected(idx) => {
                    DashboardPageData.cb-set-fan-mode(idx);
                }
            }
        }
    }
}
