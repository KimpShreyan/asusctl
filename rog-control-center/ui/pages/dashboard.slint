// ROG Control Center — Dashboard Page
// Matches ASUS Armoury Crate dashboard layout

import { ScrollView } from "std-widgets.slint";
import { ROGTheme } from "../theme.slint";
import { MonitorEntry, ProductInfo, FanModeEntry } from "../types/monitor_types.slint";

// ── Data global (set from Rust) ──

export global DashboardPageData {
    in-out property <ProductInfo> product: {
        product-name: "ASUS ROG Laptop",
        cpu-name: "",
        gpu-name: "",
        ram-info: "",
        bios-version: "",
    };

    // Device-centric monitoring (matches Armoury Crate layout)
    in-out property <[MonitorEntry]> cpu-entries: [];
    in-out property <[MonitorEntry]> gpu-entries: [];
    in-out property <[MonitorEntry]> fan-entries: [];
    in-out property <[MonitorEntry]> storage-entries: [];

    // GPU may not be present (Intel-only laptops)
    in-out property <bool> gpu-available: false;

    // Operation mode (Silence / Performance / Turbo)
    in-out property <int> active-fan-mode: 1;
    in-out property <[FanModeEntry]> fan-modes: [
        { label: "Silence", active: false },
        { label: "Performance", active: true },
        { label: "Turbo", active: false },
    ];

    callback cb-set-fan-mode(int);
}

// ── Section header with ROG accent marker ──

component SectionHeader inherits Rectangle {
    in property <string> text;
    height: 32px;

    HorizontalLayout {
        spacing: ROGTheme.spacing-sm;
        alignment: start;

        // Red accent marker
        Rectangle {
            width: 4px;
            height: 16px;
            y: (parent.height - self.height) / 2;
            background: ROGTheme.accent;
            border-radius: 2px;
        }

        Text {
            text: root.text;
            color: ROGTheme.text-primary;
            font-size: ROGTheme.font-heading;
            font-weight: ROGTheme.weight-bold;
            vertical-alignment: center;
        }
    }
}

// ── Monitor data row ──

component MonitorRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <float> bar-percent: 0.0;
    in property <bool> show-bar: false;
    in property <color> bar-color: ROGTheme.monitor-bar;

    height: show-bar ? 32px : 24px;
    background: transparent;

    VerticalLayout {
        spacing: 2px;

        HorizontalLayout {
            padding-left: 0px;
            padding-right: 0px;
            height: 22px;

            Text {
                text: root.label;
                color: ROGTheme.text-secondary;
                font-size: ROGTheme.font-label;
                vertical-alignment: center;
                horizontal-alignment: left;
            }

            Text {
                text: root.value;
                color: ROGTheme.text-primary;
                font-size: ROGTheme.font-label;
                vertical-alignment: center;
                horizontal-alignment: right;
            }
        }

        if root.show-bar: Rectangle {
            height: 4px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 2px;

            Rectangle {
                x: 0px;
                y: 0px;
                height: parent.height;
                width: parent.width * Math.max(0.0, Math.min(1.0, root.bar-percent));
                background: root.bar-color;
                border-radius: 2px;
            }
        }
    }
}

// ── Device monitoring card (CPU, GPU, Fan, Storage) ──

component DeviceCard inherits Rectangle {
    in property <string> title;
    in property <[MonitorEntry]> entries;

    background: ROGTheme.bg-surface;
    border-radius: ROGTheme.radius-lg;
    border-width: 1px;
    border-color: ROGTheme.border-default;
    min-height: 120px;

    VerticalLayout {
        padding: ROGTheme.spacing-lg;
        spacing: ROGTheme.spacing-xs;

        // Category header: large bold title + decorative wave accent
        HorizontalLayout {
            height: 40px;
            alignment: space-between;

            Text {
                text: root.title;
                color: ROGTheme.text-primary;
                font-size: ROGTheme.font-category;
                font-weight: ROGTheme.weight-bold;
                vertical-alignment: center;
            }

            // Decorative triple-wave accent (Armoury Crate style)
            HorizontalLayout {
                alignment: end;
                spacing: 3px;
                vertical-stretch: 0;
                width: 30px;

                Rectangle {
                    width: 6px;
                    height: 12px;
                    y: (parent.height - self.height) / 2;
                    background: ROGTheme.text-disabled;
                    border-radius: 2px;
                }
                Rectangle {
                    width: 6px;
                    height: 18px;
                    y: (parent.height - self.height) / 2;
                    background: ROGTheme.text-disabled;
                    border-radius: 2px;
                }
                Rectangle {
                    width: 6px;
                    height: 12px;
                    y: (parent.height - self.height) / 2;
                    background: ROGTheme.text-disabled;
                    border-radius: 2px;
                }
            }
        }

        // Monitor rows
        for entry[idx] in root.entries: MonitorRow {
            label: entry.label;
            value: entry.value;
            bar-percent: entry.bar-percent;
            show-bar: entry.show-bar;
            bar-color: ROGTheme.monitor-bar;
        }
    }
}

// ── Product info panel (left column) ──

component ProductInfoPanel inherits Rectangle {
    in property <ProductInfo> info;

    background: transparent;

    VerticalLayout {
        spacing: ROGTheme.spacing-lg;
        alignment: start;
        padding: ROGTheme.spacing-lg;

        // Laptop image placeholder (ROG logo)
        Rectangle {
            height: 220px;
            background: ROGTheme.bg-surface;
            border-radius: ROGTheme.radius-lg;
            border-width: 1px;
            border-color: ROGTheme.border-default;

            VerticalLayout {
                alignment: center;
                padding: ROGTheme.spacing-xl;

                Image {
                    source: @image-url("../../data/rog-control-center.png");
                    image-fit: contain;
                    max-height: 160px;
                    horizontal-alignment: center;
                }
            }
        }

        // Product name (large, bold)
        Text {
            text: info.product-name;
            color: ROGTheme.text-primary;
            font-size: 20px;
            font-weight: ROGTheme.weight-bold;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // CPU info line
        if info.cpu-name != "": Text {
            text: info.cpu-name;
            color: ROGTheme.text-secondary;
            font-size: ROGTheme.font-label;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // GPU info line
        if info.gpu-name != "": Text {
            text: info.gpu-name;
            color: ROGTheme.text-secondary;
            font-size: ROGTheme.font-label;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        // RAM + BIOS line
        if info.ram-info != "": Text {
            text: info.bios-version != ""
                ? info.ram-info + "  |  " + info.bios-version
                : info.ram-info;
            color: ROGTheme.text-disabled;
            font-size: ROGTheme.font-small;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

// ── Operating mode button (icon-style) ──

component OperatingModeButton inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked;

    width: 110px;
    height: 72px;
    background: active ? rgba(0, 212, 170, 0.1) : transparent;
    border-radius: ROGTheme.radius-md;
    border-width: active ? 1px : 0px;
    border-color: active ? ROGTheme.monitor-bar : transparent;

    animate background { duration: ROGTheme.anim-normal; }
    animate border-width { duration: ROGTheme.anim-normal; }

    VerticalLayout {
        alignment: center;
        spacing: ROGTheme.spacing-xs;
        padding: ROGTheme.spacing-sm;

        // Icon area — geometric indicator circle
        Rectangle {
            height: 28px;
            width: 28px;
            x: (parent.width - self.width) / 2;
            border-radius: 14px;
            background: root.active ? ROGTheme.monitor-bar : ROGTheme.text-disabled;
            opacity: root.active ? 1.0 : 0.4;
            animate background { duration: ROGTheme.anim-normal; }
            animate opacity { duration: ROGTheme.anim-normal; }
        }

        Text {
            text: root.label;
            color: root.active ? ROGTheme.monitor-bar : ROGTheme.text-secondary;
            font-size: ROGTheme.font-label;
            font-weight: root.active ? ROGTheme.weight-bold : ROGTheme.weight-regular;
            horizontal-alignment: center;
            animate color { duration: ROGTheme.anim-normal; }
        }
    }

    // Hover overlay
    Rectangle {
        width: 100%;
        height: 100%;
        background: ROGTheme.bg-hover;
        border-radius: ROGTheme.radius-md;
        opacity: touch.has-hover && !root.active ? 0.6 : 0.0;
        animate opacity { duration: ROGTheme.anim-fast; }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.clicked(); }
    }
}

// ── Operating mode selector ──

component OperatingModeSelector inherits Rectangle {
    in property <[FanModeEntry]> modes;
    in-out property <int> active-mode;
    callback mode-selected(int);

    background: ROGTheme.bg-surface;
    border-radius: ROGTheme.radius-lg;
    border-width: 1px;
    border-color: ROGTheme.border-default;

    VerticalLayout {
        padding: ROGTheme.spacing-lg;
        spacing: ROGTheme.spacing-md;

        HorizontalLayout {
            height: 32px;
            alignment: space-between;

            SectionHeader { text: "Operating Mode"; }
        }

        HorizontalLayout {
            spacing: ROGTheme.spacing-md;
            alignment: center;

            for entry[idx] in root.modes: OperatingModeButton {
                label: entry.label;
                active: idx == root.active-mode;
                clicked => {
                    root.active-mode = idx;
                    root.mode-selected(idx);
                }
            }
        }
    }
}

// ── Main dashboard page ──

export component PageDashboard inherits Rectangle {
    background: transparent;
    clip: true;

    ScrollView {
        VerticalLayout {
            padding: ROGTheme.spacing-xl;
            spacing: ROGTheme.spacing-xl;

            // Page title
            Text {
                text: @tr("Home");
                color: ROGTheme.text-primary;
                font-size: ROGTheme.font-title;
                font-weight: ROGTheme.weight-bold;
            }

            // Main content: product info (left) + systems monitor (right)
            HorizontalLayout {
                spacing: ROGTheme.spacing-xl;

                // Left column: Product info + laptop image
                ProductInfoPanel {
                    info: DashboardPageData.product;
                    min-width: 260px;
                    max-width: 320px;
                    horizontal-stretch: 0;
                }

                // Right column: Systems Monitor
                VerticalLayout {
                    spacing: ROGTheme.spacing-lg;
                    horizontal-stretch: 1;

                    // "Systems Monitor" header
                    SectionHeader { text: "Systems Monitor"; }

                    // Top row: CPU + GPU
                    HorizontalLayout {
                        spacing: ROGTheme.spacing-lg;

                        DeviceCard {
                            title: "CPU";
                            entries: DashboardPageData.cpu-entries;
                            horizontal-stretch: 1;
                        }

                        if DashboardPageData.gpu-available: DeviceCard {
                            title: "GPU";
                            entries: DashboardPageData.gpu-entries;
                            horizontal-stretch: 1;
                        }
                    }

                    // Bottom row: Fan + Storage
                    HorizontalLayout {
                        spacing: ROGTheme.spacing-lg;

                        DeviceCard {
                            title: "Fan";
                            entries: DashboardPageData.fan-entries;
                            horizontal-stretch: 1;
                        }

                        DeviceCard {
                            title: "Storage";
                            entries: DashboardPageData.storage-entries;
                            horizontal-stretch: 1;
                        }
                    }

                    // Operating Mode selector
                    OperatingModeSelector {
                        modes: DashboardPageData.fan-modes;
                        active-mode <=> DashboardPageData.active-fan-mode;
                        mode-selected(idx) => {
                            DashboardPageData.cb-set-fan-mode(idx);
                        }
                    }
                }
            }
        }
    }
}
