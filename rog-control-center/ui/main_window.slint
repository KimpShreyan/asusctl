import { Palette, Button, VerticalBox } from "std-widgets.slint";
import { ROGTheme } from "theme.slint";
import { AppSize } from "globals.slint";
import { SideBar, SideBarEntry } from "widgets/sidebar.slint";
import { PageDashboard, DashboardPageData } from "pages/dashboard.slint";
import { MonitorEntry, ProductInfo, FanModeEntry } from "types/monitor_types.slint";
import { PageSystem, SystemPageData, AttrMinMax } from "pages/system.slint";
import { PageAbout } from "pages/about.slint";
import { PageFans } from "pages/fans.slint";
import { PageAnime, AnimePageData } from "pages/anime.slint";
import { RogItem } from "widgets/common.slint";
import { PageAura } from "pages/aura.slint";
import { Node } from "widgets/graph.slint";
export { Node }
import { FanPageData, FanType, Profile } from "types/fan_types.slint";
export { FanPageData, FanType, Profile }
import { AuraPageData, AuraDevType, LaptopAuraPower, AuraPowerState, PowerZones, AuraEffect } from "types/aura_types.slint";
export { AuraPageData, AuraDevType, LaptopAuraPower, AuraPowerState, PowerZones, AuraEffect }
import { PageAppSettings, AppSettingsPageData } from "pages/app_settings.slint";

export { AppSize, AttrMinMax, SystemPageData, AnimePageData, AppSettingsPageData }
export { DashboardPageData, MonitorEntry, ProductInfo, FanModeEntry, SideBarEntry }

export component MainWindow inherits Window {
    title: "ROG Control";
    default-font-family: "Noto Sans";
    default-font-size: 14px;
    default-font-weight: 400;
    icon: @image-url("../data/rog-control-center.png");

    in property <[SideBarEntry]> sidebar-entries: [
        { label: "Dashboard", section: "", available: true },
        { label: "System Control", section: "Main", available: true },
        { label: "Keyboard Aura", section: "Playground", available: true },
        { label: "AniMe Matrix", section: "", available: true },
        { label: "Fan Curves", section: "Controls", available: true },
        { label: "App Settings", section: "Settings", available: true },
        { label: "About", section: "", available: true },
    ];

    private property <bool> show_notif;
    private property <bool> fade_cover;
    private property <bool> toast: false;
    private property <string> toast_text: "I show when something is waiting";

    callback show_toast(string);
    show_toast(text) => {
        toast = text != "";
        toast_text = text;
    }

    callback exit-app();

    callback show_notification(bool);
    show_notification(yes) => {
        show_notif = yes;
        fade_cover = yes;
    }

    callback external_colour_change();
    external_colour_change() => {
        aura.external_colour_change();
        aura.external_colour_change();
    }

    min-height: AppSize.height;
    min-width: AppSize.width;
    background: ROGTheme.bg-primary;

    HorizontalLayout {
        padding: 0px;

        VerticalLayout {
            side-bar := SideBar {
                title: @tr("ROG Control");
                entries: root.sidebar-entries;
            }

            // Quit button at sidebar bottom
            Rectangle {
                max-height: 40px;
                width: side-bar.width;
                background: ROGTheme.bg-secondary;

                Text {
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    text: @tr("Quit App");
                    color: ROGTheme.text-secondary;
                    font-size: ROGTheme.font-label;
                }

                TouchArea {
                    clicked => {
                        root.exit-app();
                    }
                }
            }
        }

        Rectangle {
            background: ROGTheme.bg-primary;

            // Page 0: Dashboard (always available)
            if side-bar.current-item == 0: PageDashboard {
                width: root.width - side-bar.width;
                height: root.height;
            }

            // Page 1: System Control
            if side-bar.current-item == 1: page := PageSystem {
                width: root.width - side-bar.width;
                height: root.height + 12px;
            }

            // Page 2: Keyboard Aura
            aura := PageAura {
                width: root.width - side-bar.width;
                visible: side-bar.current-item == 2;
            }

            // Page 3: AniMe Matrix
            if side-bar.current-item == 3: PageAnime {
                width: root.width - side-bar.width;
            }

            // Page 4: Fan Curves
            fans := PageFans {
                width: root.width - side-bar.width;
                visible: side-bar.current-item == 4;
            }

            // Page 5: App Settings
            if side-bar.current-item == 5: PageAppSettings {
                width: root.width - side-bar.width;
            }

            // Page 6: About
            if side-bar.current-item == 6: PageAbout {
                width: root.width - side-bar.width;
            }
        }
    }

    // Fade cover for modals
    if fade_cover: Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: rgba(0, 0, 0, 0.7);
        TouchArea {
            height: 100%;
            width: 100%;
            clicked => {
                if (show_notif) {
                    show_notif = false;
                }
                fade_cover = false;
            }
        }
    }

    // Toast notification bar
    if toast: Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: 32px;
        opacity: 1.0;

        Rectangle {
            height: 100%;
            width: 100%;
            background: ROGTheme.bg-elevated;
            border-width: 0px;
            border-color: ROGTheme.border-default;

            Text {
                color: ROGTheme.text-primary;
                text: root.toast_text;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        TouchArea {
            height: 100%;
            width: 100%;
            clicked => {
                toast = false;
            }
        }
    }

    // Notification dialog
    if show_notif: Rectangle {
        x: root.width / 8;
        y: root.height / 8;
        height: (root.height / 8) * 6;
        width: (root.width / 8) * 6;

        TouchArea {
            height: 100%;
            width: 100%;
            clicked => {
                show_notif = false;
                exit-app();
            }
        }

        Rectangle {
            height: 100%;
            width: 100%;
            background: ROGTheme.bg-elevated;
            border-radius: ROGTheme.radius-lg;
            border-width: 1px;
            border-color: ROGTheme.border-default;

            Text {
                text: "Click here to exit";
                color: ROGTheme.text-primary;
            }
        }
    }

    // Error overlay
    if SomeError.error_message != "": Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        padding: 10px;

        background: ROGTheme.bg-primary;
        border-color: ROGTheme.status-error;
        border-width: 3px;
        border-radius: ROGTheme.radius-lg;

        VerticalBox {
            RogItem {
                min-height: 50px;
                max-height: 100px;
                Text {
                    text <=> SomeError.error_message;
                    font-size: 18px;
                    color: ROGTheme.text-primary;
                }
            }

            Text {
                text <=> SomeError.error_help;
                horizontal-alignment: TextHorizontalAlignment.center;
                vertical-alignment: TextVerticalAlignment.center;
                color: ROGTheme.text-secondary;
            }
        }
    }
}

export global SomeError {
    in property <string> error_message: "";
    in property <string> error_help: "";
}
